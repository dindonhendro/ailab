# ============================================================
#  IACCLM AI Lab Assistant — Environment Variables
# ============================================================

# --- InsForge (Frontend + Functions Runtime) ---
VITE_INSFORGE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key-here

# --- SATUSEHAT Kemenkes RI (used in InsForge Functions) ---
SATUSEHAT_FHIR_URL=https://api-satusehat.kemkes.go.id/fhir-r4/v1
SATUSEHAT_MPI_URL=https://api-satusehat.kemkes.go.id/mpi/v1
SATUSEHAT_CLIENT_ID=your_client_id
SATUSEHAT_CLIENT_SECRET=your_client_secret

# --- AI via OpenRouter (used in InsForge Functions) ---
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
